# Copia questo file in ".env.local" e riempi i valori.

# --- Client (sicure: la anon key è pubblica, protetta da RLS) ---
VITE_SUPABASE_URL=https://tikcnxwqynpytysrrtaz.supabase.co
VITE_SUPABASE_ANON_KEY=
# Chiave VAPID PUBBLICA per le notifiche push (può stare nel client).
# Genera la coppia con: node -e "console.log(require('web-push').generateVAPIDKeys())"
VITE_VAPID_PUBLIC_KEY=

# --- Server / proxy AI (SOLO lato server, MAI esposte al client) ---
# Provider: Google Gemini (free tier). Key da https://aistudio.google.com/apikey
# Vive solo qui in locale (.env.local è gitignored) e nelle env var di Vercel.
GEMINI_API_KEY=
# Opzionale: modello (default gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash
# Foto ricette (Pexels, free). Key da https://www.pexels.com/api/
PEXELS_API_KEY=
# Opzionali: se assenti, il dev usa automaticamente le VITE_SUPABASE_* qui sopra.
# Su Vercel vanno impostate esplicitamente (senza prefisso VITE_).
SUPABASE_URL=https://tikcnxwqynpytysrrtaz.supabase.co
SUPABASE_ANON_KEY=
# SERVICE ROLE key (SEGRETA, pieno accesso al DB): SOLO lato server.
# Necessaria per: cancellazione account (api/account) e rate-limit AI (server/claude).
# Da Supabase: Project Settings > API > service_role. NON metterla mai in VITE_*.
SUPABASE_SERVICE_ROLE_KEY=
# Opzionale: tetto richieste AI per utente al giorno (default 80).
AI_DAILY_LIMIT=80

# --- Notifiche push (SOLO lato server, tranne la public key qui sopra) ---
# VAPID: la coppia è la stessa generata per VITE_VAPID_PUBLIC_KEY.
# La PRIVATE non deve MAI finire nel client.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Soggetto VAPID: un mailto: valido (contatto del mittente delle push).
VAPID_SUBJECT=mailto:mar8co@gmail.com
# Segreto condiviso col cron pg_cron (migration-10): protegge /api/push.
# Su Supabase va anche messo nel Vault come 'dispensa_cron_secret'.
CRON_SECRET=
