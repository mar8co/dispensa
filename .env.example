# Copia questo file in ".env.local" e riempi i valori.

# --- Client (sicure: la anon key è pubblica, protetta da RLS) ---
VITE_SUPABASE_URL=https://tikcnxwqynpytysrrtaz.supabase.co
VITE_SUPABASE_ANON_KEY=

# --- Server / proxy AI (SOLO lato server, MAI esposte al client) ---
# Provider: Google Gemini (free tier). Key da https://aistudio.google.com/apikey
# Vive solo qui in locale (.env.local è gitignored) e nelle env var di Vercel.
GEMINI_API_KEY=
# Opzionale: modello (default gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash
# Opzionali: se assenti, il dev usa automaticamente le VITE_SUPABASE_* qui sopra.
# Su Vercel vanno impostate esplicitamente (senza prefisso VITE_).
SUPABASE_URL=https://tikcnxwqynpytysrrtaz.supabase.co
SUPABASE_ANON_KEY=
