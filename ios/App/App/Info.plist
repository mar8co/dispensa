<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>it</string>
	<key>CFBundleDisplayName</key>
        <string>Dispensa</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<!-- AdMob: id APPLICAZIONE (non dell'unità pubblicitaria). Ora è quello di
	     TEST di Google; va sostituito col reale quando c'è l'account AdMob.
	     Senza questa chiave l'SDK va in crash all'avvio. -->
	<key>GADApplicationIdentifier</key>
	<string>ca-app-pub-3940256099942544~1458002511</string>
	<!-- App Tracking Transparency: testo del prompt di sistema. Obbligatorio
	     se si usa l'IDFA per la pubblicità. -->
	<key>NSUserTrackingUsageDescription</key>
	<string>Usiamo questo permesso per mostrarti pubblicità più pertinente. Puoi rifiutare: gli annunci resteranno, solo meno mirati.</string>
	<!-- Schema custom per il ritorno dal login (magic link e OAuth): Supabase
	     rimanda a dispensa://auth e il ponte in src/lib/native.js apre la
	     sessione. Va aggiunto anche ai Redirect URL consentiti su Supabase. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.mar8co.dispensa</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>dispensa</string>
			</array>
		</dict>
	</array>
	<!-- Permessi richiesti dalle funzioni esistenti: senza queste stringhe iOS
	     blocca getUserMedia e l'app viene rifiutata in review. -->
	<key>NSCameraUsageDescription</key>
	<string>Serve per inquadrare lo scontrino e i codici a barre dei prodotti da aggiungere in dispensa.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Serve per scegliere la foto di uno scontrino già scattato.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Serve per dettare a voce i prodotti da aggiungere.</string>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<!-- Solo verticale, come il manifest PWA (orientation: portrait): tutta la
	     UI è pensata per una mano sola. -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
</dict>
</plist>
